# AgentRed Backend Environment Variables
# Copy this to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-with-python-c-import-secrets-print-secrets-token-hex-32
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,https://app.agentred.io
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agentred:password@localhost:5432/agentred
DATABASE_URL_SYNC=postgresql://agentred:password@localhost:5432/agentred

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
OLLAMA_BASE_URL=http://localhost:11434

# ── AWS Storage ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=agentred-reports

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-key
FROM_EMAIL=noreply@agentred.io

# ── Billing ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# ── Integrations ──────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token
PAGERDUTY_API_KEY=your-key

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn
POSTHOG_API_KEY=phc_your-key
